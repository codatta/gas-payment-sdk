# Required for npm run example:submit / example:state / example:prepare
SENDER_PRIVATE_KEY=0x
CALL_TARGET_CONTRACT=0xYourBusinessContract

# Optional
# CALL_DATA=0x
# REQUEST_ID=
# SUBMIT_CALL_GAS=

# Optional overrides — by default everything resolves from the SDK's
# CHAIN_DEFAULTS for chainId 84532 (Base Sepolia).
# CHAIN_ID=84532
# RPC_URL=
# API_BASE_URL=
# ENTRY_POINT_ADDRESS=
# ERC3009_TOKEN_ADDRESS=
# PAYMENT_TARGET_CONTRACT=
